animations {
    workspace-switch {
        duration-ms 300
        curve "cubic-bezier" 0.05 0.9 0.1 1.05
    }
    window-open {
        duration-ms 300
        curve "cubic-bezier" 0.05 0.9 0.1 1.05
    }
    window-close {
        duration-ms 150
        curve "cubic-bezier" 0.05 0.7 0.1 1.0
    }
    window-movement {
        duration-ms 300
        curve "cubic-bezier" 0.05 0.9 0.1 1.05
    }
    window-resize {
        duration-ms 300
        curve "cubic-bezier" 0.05 0.9 0.1 1.05
    }
    horizontal-view-movement {
        duration-ms 300
        curve "cubic-bezier" 0.05 0.9 0.1 1.05
    }
    overview-open-close {
        duration-ms 500
        curve "cubic-bezier" 0.05 0.9 0.1 1.05
    }
}
